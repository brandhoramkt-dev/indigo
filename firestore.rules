rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == "brandhoramkt@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      ); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // 1. Products (Menu)
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. Blog Posts (Cultura)
    match /blogPosts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. Reservations
    match /reservations/{resId} {
      allow create: if true;
      allow list: if isAdmin();
      allow get: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 4. Admins (Lista Blanca)
    match /admins/{adminEmail} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Validation Helpers (Blueprints) ---
    // (Simplificado temporalmente para evitar rechazos por campos opcionales)
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'available']);
    }

    function isValidBlogPost(data) {
      return data.keys().hasAll(['title', 'content'])
          && data.title is string && data.title.size() > 0 && data.title.size() < 200
          && data.content is string && data.content.size() > 0
          && (data.summary == null || data.summary is string && data.summary.size() < 500)
          && (data.imageUrl == null || data.imageUrl is string);
    }

    function isValidReservation(data) {
      return data.keys().hasAll(['spotId', 'date', 'time'])
          && data.spotId is string && data.spotId.size() > 0 && data.spotId.size() < 50
          && data.date is string && data.date.size() == 10
          && data.time is string && data.time.size() >= 5 && data.time.size() <= 6
          && (data.customerName == null || data.customerName is string && data.customerName.size() < 100)
          && (data.notes == null || data.notes is string && data.notes.size() < 300)
          && (data.status == null || data.status in ['pending', 'confirmed', 'cancelled']);
    }
  }
}
