rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(incoming());
    }

    // Blog
    match /blogPosts/{postId} {
      allow read: if true;
      allow write: if isAdmin() && isValidBlogPost(incoming());
    }

    // Reservations
    match /reservations/{resId} {
      allow create: if isValidReservation(incoming());
      allow read, update, delete: if isAdmin();
    }

    // Admins list - Read only by admins
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Validation Blueprints
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100
          && data.price is number && data.price >= 0
          && data.category is string
          && (data.description == null || (data.description is string && data.description.size() < 500))
          && data.available is bool;
    }

    function isValidBlogPost(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200
          && data.content is string && data.content.size() > 0
          && (data.summary == null || data.summary is string);
    }

    function isValidReservation(data) {
      return data.spotId is string && data.spotId.size() > 0
          && data.date is string && data.date.size() == 10
          && data.time is string && data.time.size() >= 5
          && (data.notes == null || data.notes is string);
    }
  }
}
